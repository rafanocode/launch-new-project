# Convex project: {{CONVEX_PROJECT_SLUG}}
# NEXT_PUBLIC_CONVEX_URL is set locally by `npx convex dev` (your personal dev
# deployment). On Vercel/Netlify it is injected at build time by the build
# command (`npx convex deploy --cmd '...' --cmd-url-env-var-name NEXT_PUBLIC_CONVEX_URL`)
# — it is NOT a stored production env var.
NEXT_PUBLIC_CONVEX_URL=
# CI/CD deploy keys live in GitHub Secrets / Vercel env, never here:
#   CONVEX_DEPLOY_KEY_STAGING  (staging deployment)
#   CONVEX_DEPLOY_KEY_PROD     (production deployment)
